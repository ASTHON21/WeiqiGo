
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 权限校验函数：必须经过 Firebase Auth 认证
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // 用户档案：所有人可读，仅本人可写
    match /userProfiles/{userId} {
      allow read: if true;
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) && 
                    request.resource.data.id == resource.data.id; // 禁止修改 UID
      allow delete: if false; // 严禁物理删除用户数据
    }
    
    // 对局数据
    match /games/{gameId} {
      allow read: if true;
      
      // 允许登录用户创建对局，且必须是参与者之一。支持 pending 或 in-progress 初始状态。
      allow create: if isAuthenticated() && 
                      (request.resource.data.playerBlackId == request.auth.uid || 
                       request.resource.data.playerWhiteId == request.auth.uid) &&
                      (request.resource.data.status == 'pending' || request.resource.data.status == 'in-progress');
      
      // 仅允许对局参与者更新状态
      allow update: if isAuthenticated() && 
                      (request.auth.uid == resource.data.playerBlackId || 
                       request.auth.uid == resource.data.playerWhiteId) &&
                      resource.data.status != 'finished' && // 禁止修改已结束的对局
                      request.resource.data.playerBlackId == resource.data.playerBlackId &&
                      request.resource.data.playerWhiteId == resource.data.playerWhiteId &&
                      request.resource.data.boardSize == resource.data.boardSize;
      
      // 允许参与者或系统清理过期（>1小时）的对局数据
      allow delete: if isAuthenticated() && 
                      (request.auth.uid == resource.data.playerBlackId || 
                       request.auth.uid == resource.data.playerWhiteId ||
                       (resource.data.status == 'finished' && request.time > resource.data.finishedAt + duration.value(60, 'm')) ||
                       (resource.data.status == 'pending' && request.time > resource.data.startedAt + duration.value(60, 'm')));

      // 移动记录
      match /moves/{moveId} {
        allow read: if true;
        allow create: if isAuthenticated() && 
                        get(/databases/$(database)/documents/games/$(gameId)).data.status == 'in-progress' &&
                        (request.auth.uid == get(/databases/$(database)/documents/games/$(gameId)).data.playerBlackId || 
                         request.auth.uid == get(/databases/$(database)/documents/games/$(gameId)).data.playerWhiteId);
        
        // 允许在删除对局时同步清理移动记录
        allow delete: if isAuthenticated() && 
                        (request.auth.uid == get(/databases/$(database)/documents/games/$(gameId)).data.playerBlackId || 
                         request.auth.uid == get(/databases/$(database)/documents/games/$(gameId)).data.playerWhiteId ||
                         get(/databases/$(database)/documents/games/$(gameId)).data == null); 
        
        allow update: if false;
      }
    }
  }
}
