rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * Core Philosophy: This ruleset enforces a security model centered around user ownership and shared access for game participants. The primary goals are to protect private user data, ensure that only authorized players can interact with a game, and provide read-only access to completed games for all users.
     *
     * Data Structure:
     * - /userProfiles/{userId}: Stores public and private user data, owned by the user.
     * - /games/{gameId}: Contains game state, with access controlled by `playerWhiteId` and `playerBlackId` fields.
     * - /games/{gameId}/moves/{moveId}: A subcollection storing the move history for a specific game, inheriting access from its parent game.
     *
     * Key Security Decisions:
     * - User profiles (`/userProfiles`) cannot be listed by other users to protect privacy. However, individual profiles can be read by any signed-in user.
     * - Active games (`/games`) are private and can only be modified by the two players involved.
     * - Completed games are public and can be read by anyone to allow for game review and spectating.
     * - Game moves (`/moves`) are immutable once created to preserve the integrity of the game history.
     *
     * Denormalization for Authorization: The rules for the `/games/{gameId}/moves` subcollection rely on accessing the parent `/games/{gameId}` document to determine if a user is a participant. This is a secure pattern for protecting subcollection access. While the application may denormalize player IDs onto move documents for client-side performance, the security rules use a `get()` call to the parent document as the ultimate source of truth for authorization.
     *
     * Structural Segregation: The separation of `userProfiles` and `games` into distinct top-level collections allows for clear and independent security rules for each data type.
     */

    // -------------------------------------------------------------------------
    // Helper Functions
    // -------------------------------------------------------------------------

    /**
     * Checks if a user is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * Checks if the currently authenticated user is the owner of a document,
     * identified by a userId from the path.
     */
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    /**
     * Checks if a document exists. Intended for use in update/delete rules.
     */
    function isExistingDoc() {
      return resource != null;
    }
    
    /**
     * Checks if the currently authenticated user is a participant in a game.
     * Requires passing the game's data object.
     */
    function isGameParticipant(gameData) {
      return request.auth.uid == gameData.playerWhiteId || request.auth.uid == gameData.playerBlackId;
    }

    // -------------------------------------------------------------------------
    // Collection Rules: /userProfiles
    // -------------------------------------------------------------------------

    /**
     * @description Controls access to user profile documents.
     * @path /userProfiles/{userId}
     * @allow (create) An authenticated user creating their own profile document.
     *   - auth: { uid: 'user_abc' }
     *   - path: /userProfiles/user_abc
     *   - data: { id: 'user_abc', ... }
     * @deny (update) A user trying to update another user's profile.
     *   - auth: { uid: 'user_xyz' }
     *   - path: /userProfiles/user_abc
     * @principle Restricts access to a user's own data tree and enforces relational integrity on create.
     */
    match /userProfiles/{userId} {
      allow get: if isSignedIn();
      allow list: if false;
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isOwner(userId) && isExistingDoc() && request.resource.data.id == resource.data.id;
      allow delete: if isOwner(userId) && isExistingDoc();
    }

    // -------------------------------------------------------------------------
    // Collection Rules: /games
    // -------------------------------------------------------------------------

    /**
     * @description Controls access to game documents.
     * @path /games/{gameId}
     * @allow (get) Any user reading a game that has a status of 'finished'.
     *   - auth: { uid: 'any_user' }
     *   - path: /games/game_123 (where game_123 has status: 'finished')
     * @deny (update) A player trying to modify a game that is already finished.
     *   - auth: { uid: 'player_white_id' }
     *   - path: /games/game_123 (where game_123 has status: 'finished')
     * @principle Enforces shared access for game participants on active games and allows public read access for completed games.
     */
    match /games/{gameId} {
      allow get: if isGameParticipant(resource.data) || resource.data.status == 'finished';
      allow list: if isSignedIn();
      allow create: if isSignedIn() && (request.auth.uid == request.resource.data.playerWhiteId || request.auth.uid == request.resource.data.playerBlackId);
      allow update: if isGameParticipant(resource.data) && isExistingDoc() && resource.data.status == 'in-progress';
      allow delete: if isGameParticipant(resource.data) && isExistingDoc();
    }

    // -------------------------------------------------------------------------
    // Collection Rules: /games/{gameId}/moves
    // -------------------------------------------------------------------------

    /**
     * @description Controls access to the move history of a specific game.
     * @path /games/{gameId}/moves/{moveId}
     * @allow (create) A participant of the parent game creating a new move.
     *   - auth: { uid: 'player_black_id' }
     *   - path: /games/game_123/moves/move_456
     * @deny (update) Any user, including a player, trying to modify an existing move.
     *   - auth: { uid: 'player_white_id' }
     *   - path: /games/game_123/moves/move_456
     * @principle Secures a subcollection by checking permissions on the parent document, ensuring only game participants can access it. Moves are immutable.
     */
    match /games/{gameId}/moves/{moveId} {
      allow get, list: if isGameParticipant(get(/databases/$(database)/documents/games/$(gameId)).data);
      allow create: if isGameParticipant(get(/databases/$(database)/documents/games/$(gameId)).data) && request.resource.data.gameId == gameId;
      allow update: if false;
      allow delete: if false;
    }
  }
}